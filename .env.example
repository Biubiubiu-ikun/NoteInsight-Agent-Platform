APP_ENV=local
GIN_MODE=release
LOG_LEVEL=info
APP_VERSION=dev
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_TRACES_SAMPLER_ARG=0.1
OTEL_EXPORT_TIMEOUT=5s
AUTH_JWT_SECRET=replace-with-a-long-random-secret
AUTH_ACCESS_TOKEN_TTL=24h
AUTH_REFRESH_TOKEN_TTL=168h
POSTGRES_DSN=postgres://creatorinsight:creatorinsight@localhost:15432/creatorinsight?sslmode=disable
POSTGRES_SHARED_PRELOAD_LIBRARIES=pg_stat_statements
POSTGRES_LOG_MIN_DURATION_STATEMENT=1000
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
NATS_URL=nats://localhost:14222
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RETRIEVAL_READ_LIMIT=120
RATE_LIMIT_RETRIEVAL_READ_WINDOW=1m
RETRIEVAL_QUERY_TIMEOUT=4s
HTTP_WRITE_TIMEOUT=10s
QDRANT_URL=http://localhost:16333
EMBEDDING_URL=http://localhost:18082
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_REVISION=97b0c614be4d77ee51c0cef4e5f07c00f9eb65b3
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=32
RETRIEVAL_DEPENDENCY_TIMEOUT=30s
CONTAINER_HTTP_PROXY=
CONTAINER_HTTPS_PROXY=
EMBEDDING_MAX_BATCH_TOKENS=2048
EMBEDDING_MAX_BATCH_REQUESTS=8
EMBEDDING_MAX_CONCURRENT_REQUESTS=32
RECONCILE_ENABLED=true
