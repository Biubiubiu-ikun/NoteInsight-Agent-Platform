{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Biubiubiu-ikun/NoteInsight-Agent-Platform/evaluation/benchmarks/retrieval_v5/submission.schema.json",
  "title": "Retrieval Benchmark v5 Independent Review Submission",
  "type": "object",
  "additionalProperties": false,
  "required": ["case_id", "reviewer_id", "answerability", "judgments", "reviewed_at"],
  "properties": {
    "case_id": { "type": "string", "pattern": "^[A-Za-z0-9._-]{1,128}$" },
    "reviewer_id": { "type": "string", "pattern": "^[A-Za-z0-9._-]{1,64}$" },
    "answerability": {
      "enum": ["answerable", "insufficient_evidence", "no_relevant_document", "authorization_denied"]
    },
    "judgments": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/judgment" }
    },
    "reviewed_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "judgment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type", "source_id", "source_version", "relevance_grade"],
      "properties": {
        "source_type": { "enum": ["note", "note_body", "note_media", "note_comment"] },
        "source_id": { "type": "integer", "minimum": 1 },
        "source_version": { "type": "integer", "minimum": 1 },
        "relevance_grade": { "type": "integer", "minimum": 0, "maximum": 3 }
      }
    }
  }
}
