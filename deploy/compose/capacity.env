CONTAINER_PREFIX=noteinsight-capacity
BACKEND_PORT=28080
WORKER_PORT=28081
POSTGRES_PORT=25432
REDIS_PORT=16379
NATS_CLIENT_PORT=24222
NATS_MONITOR_PORT=28222
POSTGRES_SHARED_BUFFERS=512MB
POSTGRES_MAX_WAL_SIZE=2GB
POSTGRES_CHECKPOINT_TIMEOUT=15min
POSTGRES_WAL_COMPRESSION=on
POSTGRES_SHARED_PRELOAD_LIBRARIES=pg_stat_statements
POSTGRES_LOG_MIN_DURATION_STATEMENT=500
