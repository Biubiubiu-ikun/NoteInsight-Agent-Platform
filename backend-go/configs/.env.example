APP_NAME=creatorinsight-api
APP_ENV=local
LOG_LEVEL=info

AUTH_JWT_SECRET=local-dev-noteinsight-secret-change-me
AUTH_ACCESS_TOKEN_TTL=24h
AUTH_REFRESH_TOKEN_TTL=168h
AUTH_BCRYPT_COST=10

HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=60s

POSTGRES_DSN=postgres://creatorinsight:creatorinsight@localhost:15432/creatorinsight?sslmode=disable
POSTGRES_MAX_CONNS=10
POSTGRES_MIN_CONNS=1
POSTGRES_CONNECT_TIMEOUT=5s
POSTGRES_PING_TIMEOUT=3s

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_PING_TIMEOUT=3s
